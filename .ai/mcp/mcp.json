{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "YOUR_UPSTASH_CONTEXT7_API_KEY"
      ]
    },
    "superpowers": {
      "command": "npx",
      "args": [
        "-y",
        "superpowers-mcp"
      ]
    }
  }
}